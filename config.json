{
    "honeypot_name": "retr0pot",
    "author": "retr0",
    "services": {
        "ssh": {
            "enabled": true,
            "port": 2222,
            "banner": "SSH-2.0-OpenSSH_8.9p1 Ubuntu-3ubuntu0.6"
        },
        "http": {
            "enabled": true,
            "port": 8080,
            "server_header": "Apache/2.4.56 (Ubuntu)"
        },
        "ftp": {
            "enabled": true,
            "port": 2121,
